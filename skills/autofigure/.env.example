# AutoFigure Configuration
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# ── VLM Evaluation (optional, enables visual scoring) ─────────────────────
# Provider: "openai" (OpenAI-compatible: OpenRouter, Bianxie, vLLM, etc.)
#           "gemini" (Google Gemini native API)
# AUTOFIGURE_EVAL_PROVIDER=openai
# AUTOFIGURE_EVAL_API_KEY=sk-or-v1-...
# AUTOFIGURE_EVAL_BASE_URL=https://openrouter.ai/api/v1
# AUTOFIGURE_EVAL_MODEL=google/gemini-2.5-flash

# ── Enhancement (optional, enables AI image beautification) ───────────────
# Provider: "openai" or "gemini"
# See https://openrouter.ai/models for available image generation models
# AUTOFIGURE_ENHANCE_PROVIDER=openai
# AUTOFIGURE_ENHANCE_API_KEY=sk-or-v1-...
# AUTOFIGURE_ENHANCE_BASE_URL=https://openrouter.ai/api/v1
# AUTOFIGURE_ENHANCE_MODEL=google/gemini-2.5-flash-image

# Enhancement mode:
#   code2prompt — Convert SVG to text description via LLM, then enhance (best quality, default)
#   code        — Pass SVG code directly as structural reference (faster)
#   none        — No code reference, pure visual enhancement
# AUTOFIGURE_ENHANCE_INPUT_TYPE=code2prompt
# AUTOFIGURE_ENHANCE_COUNT=1

# Art style for enhancement (any descriptive phrase)
# AUTOFIGURE_ART_STYLE=Modern scientific illustration

# ── Code-to-Prompt LLM (for code2prompt enhancement mode) ─────────────────
# Defaults to eval config if not set. Only needed if enhancement uses a
# different provider than evaluation.
# AUTOFIGURE_CODE2PROMPT_API_KEY=
# AUTOFIGURE_CODE2PROMPT_BASE_URL=https://openrouter.ai/api/v1
# AUTOFIGURE_CODE2PROMPT_MODEL=google/gemini-2.5-flash

# ── Rendering ─────────────────────────────────────────────────────────────
# AUTOFIGURE_RENDER_WIDTH=1333
# AUTOFIGURE_RENDER_HEIGHT=750

# ── Pipeline ──────────────────────────────────────────────────────────────
# AUTOFIGURE_OUTPUT_DIR=./autofigure_output
# AUTOFIGURE_MAX_ITERATIONS=5
# AUTOFIGURE_QUALITY_THRESHOLD=9.0